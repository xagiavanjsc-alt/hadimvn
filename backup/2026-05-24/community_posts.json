    "content": "<h2 style=\"text-align: left;\">Chọn đáp án đúng</h2><!--StartFragment--><!--EndFragment-->\n\n<img src=\"{{storage:community-images/1777832587136_trac-nghiem-tieng-han-ve-thoi-thiet.webp}}\" alt=\"ảnh\" style=\"max-width:100%;border-radius:12px\">",
