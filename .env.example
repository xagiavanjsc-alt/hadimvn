# Supabase Configuration
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL — used by:
#   - usePageSEO hook (canonical, og:url for every page)
#   - scripts/generate-sitemap.mjs (sitemap.xml + robots.txt Sitemap line)
#   - index.html (%VITE_SITE_URL% placeholders)
# Change here when migrating domains; no other source edits needed.
VITE_SITE_URL=https://hanquocoi.vn

# Optional: Base path for deployment
BASE_PATH=/

# Apify Configuration for Melon Chart Scraper
# Get your API key from https://apify.com
VITE_APIFY_API_KEY=your-apify-api-key
